# =============================================================================
# AURA-GRID — Environment Variables (example)
# Copy the relevant blocks into apps/web/.env.local and apps/api/.env
# NEVER commit real values. Backend secrets must stay backend-only.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (apps/web/.env.local) — only VITE_* vars are exposed to the browser.
# Firebase WEB config is public by design, but kept in env for flexibility.
# -----------------------------------------------------------------------------
VITE_APP_NAME=AURA-GRID
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:4000/api
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# -----------------------------------------------------------------------------
# BACKEND (apps/api/.env) — SECRET. Never exposed to the browser.
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Gemini (backend only) — model is configurable, no hardcoding.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Firebase Admin (backend only) — SECRET service-account credentials.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_admin_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

JWT_AUDIENCE=aura-grid
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX_REQUESTS=30
CACHE_DEFAULT_TTL_SECONDS=300
GEMINI_CACHE_TTL_SECONDS=900
