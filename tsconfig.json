{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@aura-grid/shared": ["packages/shared/src/index.ts"],
      "@aura-grid/shared/*": ["packages/shared/src/*"],
      "@aura-grid/game-engine": ["packages/game-engine/src/index.ts"],
      "@aura-grid/game-engine/*": ["packages/game-engine/src/*"],
      "@aura-grid/ui": ["packages/ui/src/index.ts"],
      "@aura-grid/ui/*": ["packages/ui/src/*"]
    }
  },
  "include": [
    "packages/*/src",
    "packages/*/test",
    "apps/*/src",
    "apps/*/test"
  ]
}
